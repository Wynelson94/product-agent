# Required - Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional - GitHub integration for repo management
GITHUB_TOKEN=ghp_...

# Optional - Supabase MCP integration
SUPABASE_ACCESS_TOKEN=sbp_...

# Optional - Vercel MCP integration
VERCEL_TOKEN=...

# Optional - Enable checkpoints (default: false = fully autonomous)
ENABLE_CHECKPOINTS=false

# Optional - Audit log path
AUDIT_LOG=./agent_audit.jsonl

# v6.0 Feature flags
# ENABLE_SPEC_AUDIT=true              # Verify build matches original prompt (default: on)
# PASS_ORIGINAL_PROMPT_TO_BUILDER=true # Write ORIGINAL_PROMPT.md for builder (default: on)
# ENABLE_PROMPT_ENRICHMENT=false       # Research and expand ideas before building (default: off)
# ENABLE_FUNCTIONAL_TESTS=true         # Enhanced test categories (default: on)
# MAX_AUDIT_FIX_ATTEMPTS=1             # How many times to fix audit discrepancies

# v7.0 Swift/SwiftUI (for host mode TestFlight deployment)
# APPLE_TEAM_ID=                       # Apple Developer Team ID
# APPLE_DEVELOPER_EMAIL=               # Apple Developer account email
